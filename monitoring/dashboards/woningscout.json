{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Agent Run Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(woningscout_agent_run_seconds_bucket[5m]))",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Agent Runs (success vs error)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(woningscout_agent_runs_total{status=\"success\"}[5m])",
          "legendFormat": "{{agent_name}} success"
        },
        {
          "expr": "rate(woningscout_agent_runs_total{status=\"error\"}[5m])",
          "legendFormat": "{{agent_name}} error"
        }
      ]
    },
    {
      "title": "Agent Errors by Type",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "woningscout_agent_errors_total",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Pipeline Health",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(woningscout_agent_runs_total{status=\"success\"})",
          "legendFormat": "Total Successful Runs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["woningscout"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WoningScout Pipeline",
  "uid": "woningscout-main",
  "version": 1
}
