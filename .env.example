# WoningScout Configuration
# Copy to .env and fill in your values
# Leave FUNDA_API_KEY blank to run in demo mode with fixture data

# Funda API (optional — blank = demo mode)
FUNDA_API_KEY=

# Database
DATABASE_URL=postgresql://scout:scout_dev_pass@localhost:5432/woningscout
DB_PASS=scout_dev_pass

# Redis
REDIS_URL=redis://localhost:6379/0

# Model storage
MODEL_PATH=./models/artifacts

# Pipeline
SCAN_INTERVAL=300
TARGET_REGIONS=amsterdam,utrecht,rotterdam,den-haag

# Alerting (optional — blank = log-only mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TELEGRAM_BOT_TOKEN=

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
